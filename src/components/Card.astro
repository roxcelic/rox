---
interface Props {

}

const {} = Astro.props;
---
<div id="checkboxes">
    <input type="checkbox" name="rGroup" value="1" id="r1"/>
        <div class="box2" id="box">
            <label class="end" for="r1">
                <span class="material-symbols-outlined">menu</span>
            </label>

            <div class="box">
                <a href="/"><h3>home</h3></a>
                <div class="vertical-row"></div><a href="/blog/"><h3>blog</h3></a>
                <div class="vertical-row"></div><a href="/projects/"><h3>projects</h3></a>
                <div class="vertical-row"></div><a href="/roxie/"><h3>roxie!</h3></a>
            </div>

            <div class="box">
                <a><h3></h3></a>
            </div>

            <h2 id="curr"></h2>
            <div class="block">
                <a id="link"><div class="image" id="image"></div></a>
                <h2 id="song">
                    roxie is currently not listening too or watching anything
                </h2>
            </div>

            <button onclick="toggleClass1()">Toggle Class</button>
            <button onclick="toggleClass2()">Toggle Class2</button>

            <h2>THIS WILL BE UPDATED TO LOOK LESS CLUNKY TRUST ME PLEASE</h2>

        </div>
</div>

<script is:inline>
	const userName = 'roxcelic';

	const apiKey = '3dcf918393b09a296cdf261dea478a1f';

	let urls = document.getElementById("link");

	let images = document.getElementById("image");

	let song = document.getElementById("song");

	let curr = document.getElementById("curr");

	let x = setInterval(function(){
		fetch(`https://ws.audioscrobbler.com/2.0/?method=user.getRecentTracks&user=${userName}&api_key=${apiKey}&format=json`)
		  	.then(response => response.json())
		  	.then(data => {
				let track = data.recenttracks.track[0];
				if (track['@attr'] && track['@attr']['nowplaying']) {
				let url = track.url;
				let image = track.image[3]['#text'];
			  	let songName = track.name;
			  	let artistName = track.artist['#text'];
				song.innerHTML = (`${songName} - ${artistName}`);
				curr.innerHTML = ('roxie is currently listening to:');
				images.style.width="3vh";
				images.style.height= "3vh";
				images.style.backgroundImage=`url(${image})`;
				images.style.border = "3px solid rgb(245, 122, 169)";
				urls.href = (url);
			} else {
				song.innerHTML = ('roxie is currently not listening too or watching anything');
				curr.innerHTML = ('')
				images.style.width="0vh";
				images.style.height= "0vh";
				images.style.backgroundImage="";
				images.style.border = "";
			}
	  	})
	  	.catch(error => {
			console.error('Error fetching data from Last.fm:', error);
	  	});
	},1000);
</script>
<script is:inline>
    function toggleClass2(){
        document.documentElement.style.setProperty('--main-color', 'rgb(245, 122, 169)');
        document.documentElement.style.setProperty('--alt-color', 'rgba(255, 0, 0, 0.5)');

        document.cookie = "maincolor=light; expires=Thu, 25 Dec 2025 12:00:00 UTC; SameSite=None;";
    }
	function toggleClass1() {

		document.documentElement.style.setProperty('--main-color', 'rgba(255, 0, 0, 0.5)');
        document.documentElement.style.setProperty('--alt-color', 'rgba(25, 0, 0, 0.5)');

        document.cookie = "maincolor=dark; expires=Thu, 25 Dec 2025 12:00:00 UTC; SameSite=None;";
	}	

    function applySavedTheme() {
        console.log(getCookie('main-color'));
        
        const maincolor = getCookie('maincolor');

        if (maincolor) {
            if (maincolor == "light"){
                document.documentElement.style.setProperty('--main-color', 'rgb(245, 122, 169)');
                document.documentElement.style.setProperty('--alt-color', 'rgba(255, 0, 0, 0.5)');
            }
            if (maincolor == "dark"){
                document.documentElement.style.setProperty('--main-color', 'rgba(255, 0, 0, 0.5)');
                document.documentElement.style.setProperty('--alt-color', 'rgba(25, 0, 0, 0.5)');
            }
        }
    }

    function getCookie(name) {
        const value = `; ${document.cookie}`;
        const parts = value.split(`; ${name}=`);
        if (parts.length === 2) return parts.pop().split(';').shift();
    }

applySavedTheme();
</script>