---
interface Props {
	title: string;
}

const {title} = Astro.props;
---

<div class="box">
	<a href="/">
        <h3>index</h3>
    </a>
    <div class="vertical-row"></div>

    <a href="/blog/">
        <h3>blog</h3>
    </a>
    <div class="vertical-row"></div>

    <a href="/projects/">
        <h3>projects</h3>
    </a>
    <div class="vertical-row"></div>

    <a href="/about_me/">
        <h3>about me</h3>
    </a>
</div>

<style>
	.box{
        display: block;
		text-align: center;
        position: relative;
        margin-top: 5%;
        width: 69%;
		left: 14%;
        border: 3px solid rgb(245, 122, 169);
        background-color: rgba(255, 0, 0, 0.5);
    }
    .vertical-row {
        left: 25%;
        display: inline-block;
        height: 10px;
        width: 1.5px;
        background-color: white;
    } 
    .title{
        justify-content: center;
        text-align: center;
        font-size: 2rem;
        color: white;
        padding-top: 2.5%;
    }
    .txt{
        color: aliceblue;
        font-size: 0.6rem;
        text-align: center;
        display: inline;
        padding: 3%;
        margin-bottom: 4%;
    }
</style>
