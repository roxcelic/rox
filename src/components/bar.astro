---
interface Props {
	title: string;
}

const {title} = Astro.props;
---

<li class="box">
	<h2>
        <div class="bar">
            <marquee>
                <div class="text">
                    {title}
                </div>
            </marquee>
        </div>
	</h2>
	<p>
		
	</p>
</li>

<style>
	.bar{
        background-image: url("/rox/../../images/why.png");
        background-repeat: repeat-x;
        width: 100%;
        height: 32px;
        justify-content: center;
        margin: auto;
    }
    .text{
        color: white;
        font-size: 28px;
    }
</style>
