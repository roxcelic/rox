---
interface Props {

}

const {} = Astro.props;
---

<li class="box">
	<h2>
        <label>
            <label for="touch"><span>
                <h2 id="menu">
                    hey, Im a dropdown menu. Press me!
                </h2>
            </li></span></label>               
            <input type="checkbox" id="touch"> 
        
            <ul class="slide" id="list">
                <iframe style="border-radius:12px" src="https://open.spotify.com/embed/playlist/6mmx1UmZjFwa39CAjGQ4BJ?utm_source=generator" width="100%" height="352" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
            </ul>
        </label>
	</h2>
	<p>

	</p>
</li>

<style>
    .slide {
        clear:both;
        width:93%;
        height:0px;
        padding-left: 4%;
        overflow: hidden;
        text-align: center;
        transition: height .4s ease;
    }

    #touch {position: absolute; opacity: 0; height: 0px;}    
  
    #touch:checked + .slide {height: 5%;} 

    label {
        display: block;
		text-align: center;
        position: relative;
        margin-top: 2.5%;
        width: 69%;
		left: 14%;
        padding-bottom: 1%;
    }

    label input {
        display: none;
    }
    ul {
        transform: scaleY(0);    
        transform-origin: top;
        transition: transform 0.26s ease;
    }
    .sample #list{
        display: block;
        width: 100%;
        height: 0px;
    }
    .sample #list ::after{
        display: block;
        width: 100%;
        height: 350px;
    }
    input:checked ~ .sample #list{
        transform: scaleY(1);
    }
</style>
