---
interface Props {
	title: string;
}

const { title } = Astro.props;
import Box from '../components/Card.astro';
import Bar from '../components/bar.astro';
import '../res/css/style.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/rox/images/icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Bar
			{title}
		/>
		<Box
			{title}
		/>
		<div class="mainBox">
			<div class="pictureBox" style="background-image: url('/rox/images/wallpaper.jpg');"></div>
			<slot />
		</div>
	</body>
</html>
<style is:global>
	
</style>
<script is:inline>

</script>
