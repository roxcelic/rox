---
interface Props {
	title: string;
}

const { title } = Astro.props;
import Bar from '../components/bar.astro';
import Box from '../components/Card.astro';
import '../res/css/style.css';
import '../res/js/set.js';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="the worlds coolest website (because it was made by me)" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="https://avatars.githubusercontent.com/u/157179472?v=4">
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons"rel="stylesheet">

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Box

		/>
		<div class="mainBox" id="mainBox">
			<div class="pictureBox"></div>
			<a href="https://github.com/roxcelic">
				<div class="roundThing"></div>
			</a>
			<slot />
		</div>
		<Bar
			{title}
		/>
	</body>
</html>
<style is:global>
	body{
		margin: 0;
    	padding: 0;
	}
</style>
