---
import Layout from '../layouts/Layout.astro';
import BlogPost from '../components/blog.astro';
const allPosts = await Astro.glob('../pages/posts/*.md');
---

<Layout title="blog">
	<main>
            <!--this down is what you change-->
            <h4>welcome to my blog</h4>
            <h2>this pafe has gone through a lot of changes so things might not be where they used to be
                such as things that are tetnically projects are now in the projects tab so it hopefully wont be 
                too confusing in that case, and i have re-posted all old blog posts, but expect new ones to be made!
            </h2>
            <h2>-decending order-</h2>

            <!--hi i made this the blog list now so please dont delete this, thx <3-->
            <h4>welcome to the blog list</h4>
    	{allPosts.map((post) => <BlogPost url={post.url} title={post.frontmatter.title} dates={post.frontmatter.pubDate} desc={post.frontmatter.desc} />)}
	</main>
</Layout>

<style>
	main {
    	list-style-type: none;
	}
</style>
