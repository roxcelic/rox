		width: 100px;
	}
	.drink{
		display: flex;
		margin-left: 7.5%;
	}
	.content{
		width: 90%;
		margin-left: 5%;
		display: flex;
		margin-top: 5%;
		margin-bottom: 5%;
	}
	.content2{
		margin-top: 5%;
		width: 90%;
		margin-left: 5%;
	}
	.roundThing2{
        height: 100px;
        width: 100px;
        background-color: pink;
        background-image: url('../../images/pfp.jpg');
        background-size: cover;
        border-radius: 5%;
        display: flexbox;
        margin: 1%;
		margin-left: 10%;
    }
	.texts{
		padding-top: 30px;
		margin-left: 5%;
		display: inline-block;
	}
</style>
