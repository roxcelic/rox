								}
							}
						}

						var passing = passing + 1
						var count2 = count
				
						if (count.join("") == figure){
							end = "true"
							output = passing
						}
					}
				}   
				output2 = output2 + String.fromCharCode(passing)
				counter = 0
				figure = ""
				passing = 1 
				count = [3,3,3,3,3,3,3,3,3]
				end = "false"
			}
		}   
		document.getElementById("output").innerHTML = output2
		copyContent(output2);
	}
</script>
