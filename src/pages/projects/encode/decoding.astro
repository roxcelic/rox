<script is:inline>

	const copyContent = async (text) => {
		try {
			await navigator.clipboard.writeText(text);
			window.alert('Content copied to clipboard');
			} catch (err) {
			console.error('Failed to copy: ', err);
			window.alert('Failed to copy: ', err);
			}
		}

	function myFunction(){
		var input = document.getElementById("input").value;
		var output = "0"
		var count = [3,3,3,3,3,3,3,3,3]
		var passing = 1
		var counting = "false"
		var item = 7
		var end = "false"
		var text = input
		var count3 = ""
		var counter = 0
		var figure = ""
		var output2 = ""

		for (items in input){
			if (counter != 8){
				figure = figure + input[items]
				counter = counter + 1  
			}
			if (counter == 8){
				figure = figure + "3"
				while (end == "false"){
					if (passing != 0){
						var counting = "true"
						while (counting == "true"){
							if (count[item] == 3){
								count[item] = count[item] + 1
								if (item != 8){
									var item = 8
									var counting = "false"
								}
							}
