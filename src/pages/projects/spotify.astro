---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="spotify">
	<main>
		<h2 id="hidden">hiii, welcome to my music!</h2>
		<div class="spotify" id="spotify">
        	<h2><iframe style="border-radius:12px" src="https://open.spotify.com/embed/playlist/6mmx1UmZjFwa39CAjGQ4BJ?utm_source=generator" width="100%" height="352" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe></h2>
		</div>
		<div class="spotify-h" id="spotify-h">
			<h2><iframe style="border-radius:12px" src="https://open.spotify.com/embed/playlist/37i9dQZF1E39p8b4gLGaZ2?utm_source=generator" width="100%" height="352" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe></h2>
		</div>
	</main>
</Layout>

<style>
	.spotify{
		display: block;
	}
	.spotify-h{
		display: none;
	}
</style>
<script src="https://code.jquery.com/jquery-3.5.1.min.js" is:inline></script>
<script is:inline>
	const alt = document.getElementById("hidden")
	const d1 = document.getElementById("spotify");
	const d2 = document.getElementById("spotify-h");
    linebreak = document.createElement("br");
    var item = 0;
    var word = "shhh";
    var key_list = "";

    document.addEventListener(
        "keydown",
        function(event){
            var current_key = event.key;
            console.log('current_key: ',current_key);
            if(current_key == word[item]){
                key_list = key_list + current_key;
                item++;
                console.log('key_list: ',key_list);
            }
            else{
                key_list = "";
                item = 0;
                console.log("sorry wrong letter");
            }
            if(key_list == word){
                console.log("omg you did it yayyy");
                key_list = "";
                item = 0;

	   			spotify(d1, d2);
            }
        },
    );

	function spotify(d1, d2){

		if( d1.style.display == "none" )
	   	{
		  	d2.style.display = "none";
		  	d1.style.display = "block";
			alt.innerText = "hiii, welcome to my music!";
	   	}
	   	else
	   	{
		  	d2.style.display = "block";
		  	d1.style.display = "none";
			alt.innerText = "hiii, welcome to my hidden music!";
	   	}
	}

</script>