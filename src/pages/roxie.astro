                spotify - roxie
            </a>
        </h2>
	</main>
</Layout>

<style>

</style>
<script is:inline type="text/javascript">
    //variables
    const userName = 'roxcelic';

	const apiKey = '3dcf918393b09a296cdf261dea478a1f';

	let song = document.getElementById("song");

    let curr = document.getElementById("curr");

    //text stuff
    function item_hover(description, ids) {
        document.getElementById(ids).innerHTML = description;
    }

    //song data!
    let x = setInterval(function(){
		fetch(`https://ws.audioscrobbler.com/2.0/?method=user.getRecentTracks&user=${userName}&api_key=${apiKey}&format=json`)
  			.then(response => response.json())
  			.then(data => {
    		const track = data.recenttracks.track[0];
    		if (track['@attr'] && track['@attr']['nowplaying']) {
      			const songName = track.name;
      			const artistName = track.artist['#text'];
      			console.log(`Currently playing: ${songName} by ${artistName}`);
				song.innerHTML = (`${songName} - ${artistName}`);
                curr.innerHTML = ('roxie is currently listening to:')
    		} else {
      			console.log('Not currently playing any track.');
				song.innerHTML = ('this page will be used for my socials or my school stuff, just kinda me. and if im listening to anything itll show up here so');
                curr.innerHTML = ('')
    		}
  		})
  		.catch(error => {
    		console.error('Error fetching data from Last.fm:', error);
  		});
	},5000);

</script>
<style>
    .lineline{
        left: 10%;
        margin: 1%;
        display: inline-block;
        height: 2.5px;
        width: 80%;
        background-color: white;
    }
</style>