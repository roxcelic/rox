</Layout>

<style>
    .image{
        height: 0px;
        width: 0px;
        background-size: contain;
        display: inline-block;
    }
</style>
<script is:inline type="text/javascript">
    //variables
    const userName = 'roxcelic';

	const apiKey = '3dcf918393b09a296cdf261dea478a1f';

    let urls = document.getElementById("link");

    let images = document.getElementById("image");

	let song = document.getElementById("song");

    let curr = document.getElementById("curr");

    //text stuff
    function item_hover(description, ids) {
        document.getElementById(ids).innerHTML = description;
    }

    //song data!
    let x = setInterval(function(){
		fetch(`https://ws.audioscrobbler.com/2.0/?method=user.getRecentTracks&user=${userName}&api_key=${apiKey}&format=json`)
  			.then(response => response.json())
  			.then(data => {
    		let track = data.recenttracks.track[0];
    		if (track['@attr'] && track['@attr']['nowplaying']) {
                let url = track.url;
                let image = track.image[3]['#text'];
      			let songName = track.name;
      			let artistName = track.artist['#text'];
				song.innerHTML = (`${songName} - ${artistName}`);
                curr.innerHTML = ('roxie is currently listening to:');
                images.style.width="20vh";
                images.style.height= "20vh";
                images.style.backgroundImage=`url(${image})`;
                images.style.border = "3px solid rgb(245, 122, 169)";
                urls.href = (url);
    		} else {
      			console.log('Not currently playing any track.');
				song.innerHTML = ('this page will be used for my socials or my school stuff, just kinda me. and if im listening to anything itll show up here so');
                curr.innerHTML = ('')
                images.style.width="0vh";
                images.style.height= "0vh";
                images.style.backgroundImage="";
                images.style.border = "";
    		}
  		})
  		.catch(error => {
    		console.error('Error fetching data from Last.fm:', error);
  		});
	},1000);

    let countDownDate = new Date(Date.UTC (2024, 5, 21, 14, 55, 0)).getTime();
        new Date(new Date().toLocaleString('en', {timeZone: 'America/New_York'}))
        
        let x3 = setInterval(function(){
            let now = new Date().getTime();
            let distance = countDownDate - now;
        
            if (distance > 0){
                let weeks = Math.floor(distance / (1000 * 60 * 60 * 24 * 7));
                let days = Math.floor(distance / (1000 * 60 * 60 * 24));
                let hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                let minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                let seconds = Math.floor((distance % (1000 * 60)) / 1000);

                document.getElementById("days").innerHTML = days
                document.getElementById("hours").innerHTML = hours
                document.getElementById("minutes").innerHTML = minutes
                document.getElementById("seconds").innerHTML = seconds
            } if (distance = 0 || distance < 0){
                document.getElementById("days").innerHTML = 0
                document.getElementById("hours").innerHTML = 0
                document.getElementById("minutes").innerHTML = 0
                document.getElementById("seconds").innerHTML = 0
                document.getElementById("free").innerHTML = ("IM FREE!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!")
            }
        },1000);

        let countDownDate2 = new Date(Date.UTC (2024, 2, 28, 14, 55, 0)).getTime();
        new Date(new Date().toLocaleString('en', {timeZone: 'America/New_York'}))
        let x2 = setInterval(function(){
            let now2 = new Date().getTime();
            let distance = countDownDate2 - now2;
        
            if (distance > 0){
                let days = Math.floor(distance / (1000 * 60 * 60 * 24));
                let hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                let minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                let seconds = Math.floor((distance % (1000 * 60)) / 1000);

                document.getElementById("days2").innerHTML = days
                document.getElementById("hours2").innerHTML = hours
                document.getElementById("minutes2").innerHTML = minutes
                document.getElementById("seconds2").innerHTML = seconds
            } if (distance = 0 || distance < 0){
                document.getElementById("days2").innerHTML = 0
                document.getElementById("hours2").innerHTML = 0
                document.getElementById("minutes2").innerHTML = 0
                document.getElementById("seconds2").innerHTML = 0
                document.getElementById("free").innerHTML = ("finnaly I have a break, also ive probably forgotten to update this just now")
            }
        },1000);

</script>
<style>
    .lineline{
        left: 10%;
        margin: 1%;
        display: inline-block;
        height: 2.5px;
        width: 80%;
        background-color: white;
    }
</style>